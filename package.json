{
  "private": true,
  "license": "ISC",
  "type": "module",
  "scripts": {
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "format": "prettier --write --experimental-cli .",
    "lint": "eslint . --ext .vue,.js,.ts,.jsx,.tsx,.md,.json --max-warnings 0 --cache --concurrency=auto",
    "lint:fix": "pnpm run lint --fix",
    "typecheck": "pnpm run \"/^typecheck:/\"",
    "typecheck:web": "vue-tsc -p tsconfig.web.json --composite false --noEmit",
    "typecheck:play": "vue-tsc -p tsconfig.play.json --composite false --noEmit",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:vite-config": "vue-tsc -p tsconfig.vite-config.json --composite false --noEmit",
    "typecheck:vitest": "vue-tsc -p tsconfig.vitest.json --composite false --noEmit"
  },
  "dependencies": {
    "@element-plus/icons-vue": "catalog:",
    "@qi-ui/components": "workspace:*",
    "@qi-ui/constants": "workspace:*",
    "@qi-ui/directives": "workspace:*",
    "@qi-ui/hooks": "workspace:*",
    "@qi-ui/locale": "workspace:*",
    "@qi-ui/test-utils": "workspace:*",
    "@qi-ui/theme-chalk": "workspace:*",
    "@qi-ui/utils": "workspace:*",
    "@types/lodash": "^4.17.21",
    "@types/lodash-es": "^4.17.12",
    "async-validator": "^4.2.5",
    "dayjs": "^1.11.19",
    "lodash": "^4.17.21",
    "lodash-es": "^4.17.22",
    "lodash-unified": "catalog:",
    "memoize-one": "^6.0.0",
    "normalize-wheel-es": "^1.2.0"
  },
  "devDependencies": {
    "@pnpm/types": "^1001.2.0",
    "@qi-ui/build": "workspace:^",
    "@qi-ui/build-utils": "workspace:^",
    "@qi-ui/eslint-config": "workspace:*",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^25.0.3",
    "@vitejs/plugin-vue": "catalog:",
    "@vitejs/plugin-vue-jsx": "catalog:",
    "eslint": "^9.39.2",
    "jsdom": "^27.4.0",
    "prettier": "^3.7.4",
    "resize-observer-polyfill": "^1.5.1",
    "sass": "^1.97.2",
    "typescript": "^5.5.4",
    "vitest": "^4.0.16",
    "vue": "catalog:",
    "vue-tsc": "^3.2.2"
  }
}
